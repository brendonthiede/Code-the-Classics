{
	"name": "Code the Classics – Browser Native (pygbag)",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "../..",
		"args": {
			// Update 'VARIANT' to pick a Python version: 3.12-bookworm, 3.11-bookworm
			"VARIANT": "3.12-bookworm"
		}
	},

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python"
			},
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-python.pylint",
				"ms-python.black-formatter"
			]
		}
	},

	// pygbag dev server – the game runs directly in your browser, no VNC required.
	"forwardPorts": [8000],

	// postStartCommand is intentionally omitted. Run the server manually:
	//   bash soccer-web/build.sh && python3 soccer-web/serve.py
	// This avoids port-8000 conflicts with the static serve.py workflow.

	"remoteUser": "vscode",

	"portsAttributes": {
		"8000": {
			"label": "Soccer Game (browser)",
			"onAutoForward": "openBrowser",
			// "public" is required so the pygbag WASM runtime can reach the
			// pygame-web.github.io CDN without CORS/COEP errors via the forwarded URL.
			"visibility": "public"
		}
	}
}
